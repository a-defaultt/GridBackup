# =============================================================================
# Client Backup Agent — Environment Configuration Blueprint
# =============================================================================
# Copy this file to .env and populate all REPLACE_WITH_* values before running
# install.sh. This file is safe to commit; .env must NEVER be committed.
# =============================================================================

# --- Core Metadata -----------------------------------------------------------
CLIENT_NAME="default-client-production"
HOST_IDENTIFIER="primary-app-server"

# --- Restic Cryptography Secret ----------------------------------------------
# Generate with: openssl rand -base64 48
RESTIC_PASSWORD="REPLACE_WITH_CRYPTOGRAPHICALLY_SECURE_PASSPHRASE"

# --- Target Repositories -----------------------------------------------------
LOCAL_REPO_PATH="/mnt/backups/local-restic-repo"
REMOTE_S3_REPO="s3:s3.us-east-1.wasabisys.com/client-unique-bucket-name"

# --- S3 Cryptographic Provider Credentials ----------------------------------
AWS_ACCESS_KEY_ID="REPLACE_WITH_S3_ACCESS_KEY"
AWS_SECRET_ACCESS_KEY="REPLACE_WITH_S3_SECRET_KEY"

# --- Monitoring and Alerting Webhooks ----------------------------------------
# Healthchecks.io ping URL (obtain from https://healthchecks.io)
HEALTHCHECKS_IO_URL="https://hc-ping.com/your-unique-uuid-here"
# ntfy.sh push notification endpoint (https://ntfy.sh)
NOTIFY_WEBHOOK_URL="https://ntfy.sh/your-secure-topic-here"

# --- Resource and Safety Thresholds ------------------------------------------
# Maximum allowed duration (minutes) for a single database dump before abort
MAX_DB_DUMP_DURATION_MINUTES="20"
# Minimum free disk percentage required before backup proceeds
MIN_FREE_DISK_PERCENT="15"
# Transient staging area used for database dumps; cleared after every run
TEMPORARY_DUMP_DIR="/var/tmp/backup_stage"
